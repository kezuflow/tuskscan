PORT=8787
TUSKSCAN_ENV=production
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
DATABASE_URL=<supabase postgres connection string>

# Real Sui payment verification.
TUSKSCAN_PACKAGE_ID=<published move/tuskscan package id>
TUSKSCAN_OPERATOR_ADDRESS=<operator wallet address paid by create_audit_job>

# Real Sui report finalization.
TUSKSCAN_OPERATOR_CAP_ID=<OperatorCap object id from move/tuskscan publish>
TUSKSCAN_OPERATOR_PRIVATE_KEY=<operator Ed25519 private key>

# Real Walrus artifacts through the Walrus TypeScript SDK.
WALRUS_AGGREGATOR_URL=<walrus aggregator url>
WALRUS_STORAGE_EPOCHS=3
WALRUS_WRITE_TIMEOUT_MS=120000

# Queue processing. Keep this off in dev; apps/api starts a dedicated DB queue worker.
TUSKSCAN_PROCESS_JOBS_IN_API=0

# Optional fallback only if you run a private authenticated publisher.
# WALRUS_PUBLISHER_URL=<walrus publisher url>

# Real MemWal memory.
MEMWAL_PRIVATE_KEY=<MemWal delegate/private key>
MEMWAL_ACCOUNT_ID=<MemWal account id>
MEMWAL_NAMESPACE=tuskscan
MEMWAL_SERVER_URL=<optional MemWal server url>
MEMWAL_WAIT_FOR_REMEMBER=1
MEMWAL_TIMEOUT_MS=120000

# Optional OpenRouter LLM agents for researcher/exploit/critic passes.
# OPENROUTER_API_KEY is enough to enable the OpenRouter defaults below.
OPENROUTER_API_KEY=<OpenRouter API key>
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=TuskScan

# Optional sandbox execution for GitHub source packages.
# Requires git and sui in PATH on the API machine.
TUSKSCAN_RUN_MOVE_TESTS=0
TUSKSCAN_SANDBOX_TIMEOUT_MS=120000
TUSKSCAN_SUI_BIN=sui
